#!/usr/bin/env sh

# somewhat POSIX bootstrap script.

set -o errexit
set -o nounset

REPO_URL="https://github.com/ndbaker1/dotfiles"
DOTFILES_GIT_DIR="$HOME/.dotfiles.git"

git_dotfiles() {
  git --git-dir=$DOTFILES_GIT_DIR --work-tree=$HOME $@
}

ask() {
  printf "$1" >&2
  read confirm < /dev/tty
  printf "%s" "$confirm"
}

# if not installed then prompt for install.
if ! [ -d $DOTFILES_GIT_DIR ] ; then
  if [ "$(ask "pull dotfiles from $REPO_URL (y/n)? ")" = "y" ] ; then 
    # clone the bare repo and use the home directory as the worktree.
    git clone --bare $REPO_URL $DOTFILES_GIT_DIR

    # dont show untracked files, let the user add files to the dotfiles
    # selectively without being bothered.
    git_dotfiles config --local status.showUntrackedFiles no

    # if the checkout failed, then try to reset the repo to the head pointer as
    # a correctness fallback.
    if ! git_dotfiles checkout ; then
      if [ "$(ask "failed to checkout. reset head [git reset --hard] (y/n)? ")" = "y" ] ; then
        git_dotfiles reset --hard
      fi
    fi

    printf "Done.\n"
    printf "Use 'dot' to invoke 'git' from the dotfiles context.\n"
  else
    printf "Aborted.\n"
  fi
else
  git_dotfiles $@
fi
